pipeline {
    agent {
        label 'worker'
    }

    environment {
        my_aws_credential = credentials('aws-access')
    }

    tools {
        maven 'maven1'
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/mayurpandit25/EasyCRUD.git'
                echo 'clonning is successful'
            }
        }

        stage('Build') {
            steps {
                dir('backend') {
                    sh 'mvn clean package'
                }
                echo 'Build is successful'
            }
            post {
                success {
                    archiveArtifacts artifacts: 'backend/target/*.jar', fingerprint: true
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar') {
                    dir('backend') {
                        sh 'mvn sonar:sonar'
                    }
                }
            }
        }
        
        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    script {
                        try {
                            def qg = waitForQualityGate()
                            echo "Quality Gate Status: ${qg.status}"
                            if (qg.status != 'OK') {
                                error "Quality Gate failed: ${qg.status}"
                            }
                        } catch (Exception e) {
                            echo "Quality Gate check failed: ${e.message}"
                            error "Quality Gate stage failed"
                        }
                    }
                }
            }
        }

        stage('SonarQube Report') {
            steps {
                script {
                    echo "SonarQube Report successfully generated"
                }
            }
        }

        stage('Build With Docker') {
            steps {
                dir('backend') {
                    sh '''
                    docker build -t backend .
                    docker images
                    '''
                }
            }
        }

        stage('Push Image To ECR') {
            steps {
                script {
                    sh '''
                    aws ecr get-login-password --region us-east-2 | docker login --username AWS --password-stdin 506995420953.dkr.ecr.us-east-2.amazonaws.com
                    docker tag backend:latest 506995420953.dkr.ecr.us-east-2.amazonaws.com/backend:latest
                    docker push 506995420953.dkr.ecr.us-east-2.amazonaws.com/backend:latest
                    '''
                }
            }
        }

        stage('Deploy To EKS') {
            steps {
                dir('backend') {
                    sh '''
                    kubectl apply -f backend-deployment.yaml
                    kubectl apply -f backend-svc.yaml
                    kubectl get pods
                    sleep 30
                    kubectl get pods
                    sleep 20
                    kubectl get pods -o wide
                    kubectl get svc -o wide
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline succeeded.'
        }
        failure {
            echo 'Pipeline failed.'
        }
    }
}
