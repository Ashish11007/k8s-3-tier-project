pipeline {
    agent {
        label 'worker'
    }

    environment {
        my_aws_access = credentials('aws-access')
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/mayurpandit25/EasyCRUD.git'
                echo 'clonning is successful'
            }
        }

        stage('Build Frontend') {
            steps {
                dir('frontend') {
                    sh 'npm install'
                    sh 'npm run build'
                }
                echo 'Build is successful'
            }
            post {
                always {
                    archiveArtifacts artifacts: 'frontend/dist/**', fingerprint: true
                }
            }
        }

        stage('Build With Docker') {
            steps {
                dir('frontend') {
                    sh 'docker build -t frontend .'
                }
                echo 'Docker Build is successful'
            }
        }

        stage('docker push to ECR') {
            steps {
                sh '''
                aws ecr get-login-password --region us-east-2 | docker login --username AWS --password-stdin 506995420953.dkr.ecr.us-east-2.amazonaws.com
                docker tag frontend:latest 506995420953.dkr.ecr.us-east-2.amazonaws.com/frontend:latest
                docker push 506995420953.dkr.ecr.us-east-2.amazonaws.com/frontend:latest
                '''
            }
        }

        stage('Deploy to EKS') {
            steps {
                dir('frontend') {
                    sh '''
                    aws eks update-kubeconfig --name my-eks-cluster --region us-east-2
                    kubectl apply -f frontend-deployment.yaml
                    kubectl apply -f frontend-svc.yaml
                    sleep 30
                    kubectl get pods
                    sleep 30
                    kubectl get pods
                    kubectl get svc -o wide
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline succeeded'
        }
        failure {
            echo 'Pipeline failed'
        }
    }
}

